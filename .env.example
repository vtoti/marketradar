# === Radar de Mercado — configuração ===
# Copie este arquivo para ".env" e preencha o que precisar.

# Mercado Livre — token estático simples (uso local/manual, expira em ~6h).
ML_ACCESS_TOKEN=

# Site do Mercado Livre (MLB = Brasil, MLA = Argentina, MLM = México...)
ML_SITE=MLB

# --- Mercado Livre OAuth (para refresh automático / coleta 24/7) ---
# Crie um app em https://developers.mercadolivre.com.br. O redirect_uri precisa
# bater EXATAMENTE com o cadastrado no app. Depois rode `python mlauth.py url`.
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=https://localhost:8501
# Preenchido automaticamente por mlauth.py; pode colar aqui para bootstrap.
ML_REFRESH_TOKEN=

# --- App / deploy ---
# Senha do dashboard. Vazio = sem login (uso local). DEFINA em produção!
APP_PASSWORD=
# Hora (0–23) da coleta diária automática do scheduler.
RUN_HOUR=8
# Anúncios coletados por termo na coleta automática.
COLLECT_LIMIT=60

# --- Domínio / HTTPS (Caddy) ---
# Seu domínio, exatamente como o DNS aponta para o IP do VPS (sem http://).
DOMAIN=radar.seudominio.com.br
# E-mail para o Let's Encrypt (opcional, recomendado).
ACME_EMAIL=voce@email.com
# Coleta uma vez assim que o scheduler sobe (1 p/ testar o deploy, 0 normal).
RUN_ON_START=0

# --- Bling (ERP) — análise de margem dos pedidos ---
# Crie um app em https://developer.bling.com.br com escopos de LEITURA de
# "Pedidos de venda" e "Produtos". O link de redirecionamento cadastrado lá
# precisa bater EXATAMENTE com BLING_REDIRECT_URI (em produção use
# https://SEU-DOMINIO/Pedidos_Bling).
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_REDIRECT_URI=http://localhost:8501/Pedidos_Bling

# Shopee — região (br, sg...). A coleta usa endpoints internos e pode exigir
# cookies válidos do navegador. Cole o cabeçalho Cookie completo se necessário.
SHOPEE_REGION=br
SHOPEE_COOKIE=

# Atraso entre requisições (segundos) para evitar bloqueio por rate limit.
REQUEST_DELAY=1.0
