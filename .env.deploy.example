# ============================================================
#  Radar de Mercado — .env de PRODUÇÃO (VPS + domínio + HTTPS)
#  No servidor:  cp .env.deploy.example .env  &&  nano .env
#  Troque os valores em MAIÚSCULAS. Só isto é obrigatório.
# ============================================================

# --- Domínio / HTTPS (Caddy) ---
# Igual ao registro A do DNS que aponta para o IP do VPS (sem http://).
DOMAIN=gsvecomm.tech
# E-mail para o certificado Let's Encrypt.
ACME_EMAIL=VOCE@EMAIL.com

# --- Acesso ao dashboard ---
# Senha de login. USE UMA SENHA FORTE.
APP_PASSWORD=TROQUE-POR-UMA-SENHA-FORTE

# --- Mercado Livre OAuth (refresh automático / 24-7) ---
# Do app criado em https://developers.mercadolivre.com.br
ML_CLIENT_ID=SEU_CLIENT_ID
ML_CLIENT_SECRET=SEU_CLIENT_SECRET
# DEVE ser idêntico ao "URI de redirect" cadastrado no app do ML:
ML_REDIRECT_URI=https://gsvecomm.tech

# ============================================================
#  Daqui para baixo os padrões já servem — só ajuste se quiser.
# ============================================================

ML_SITE=MLB
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=

# Coleta automática
RUN_HOUR=8            # hora do dia (0–23) da coleta diária
COLLECT_LIMIT=60      # anúncios por termo
RUN_ON_START=0        # 1 = coleta assim que o scheduler sobe (para testar)

# Shopee (fase 2 — provavelmente bloqueado a partir do VPS)
SHOPEE_REGION=br
SHOPEE_COOKIE=

# Rede
REQUEST_DELAY=1.0
